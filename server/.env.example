# Copy to .env.local for `vercel dev`, and set the same keys in the Vercel
# project's dashboard (Settings → Environment Variables) for the real deploy.
# Test-mode secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# create-checkout-session.ts only (web tip flow) — the deployed web app's
# origin, no trailing slash. Checkout redirects the browser back here after
# payment. e.g. https://your-portfolio.vercel.app
WEB_APP_URL=https://your-portfolio.vercel.app
