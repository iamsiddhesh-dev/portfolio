# Copy to .env.local (gitignored) and fill in from https://dashboard.clerk.com/last-active?path=api-keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (test mode) — publishable key from https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of the deployed serverless endpoint (see server/), e.g.
# https://portfolio-tips.vercel.app — no trailing slash
EXPO_PUBLIC_API_BASE_URL=https://your-deployment.vercel.app
